# Required by `tasks serve`. Generate a long random value; never commit .env.
TASKS_SECRET=replace-with-a-long-random-secret

# Required by every command. Tasks are stored in PostgreSQL.
TASKS_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/tasks?sslmode=disable

TASKS_ADDR=127.0.0.1:8080
TASKS_PUBLIC_URL=https://tasks.hackclub.com

# Used only as the default parent directory for local image storage below.
TASKS_DATA_DIR=./data

# Local image storage (development default).
TASKS_OBJECT_STORE=local
TASKS_LOCAL_OBJECT_DIR=./data/images

# S3-compatible image storage (production alternative).
# TASKS_OBJECT_STORE=s3
# TASKS_S3_ENDPOINT=s3.example.com
# TASKS_S3_ACCESS_KEY=replace-me
# TASKS_S3_SECRET_KEY=replace-me
# TASKS_S3_BUCKET=tasks-images
# TASKS_S3_REGION=us-east-1
# TASKS_S3_USE_SSL=true

# Set to a reachable PostgreSQL server to run the Postgres-backed tests.
# TASKS_TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
