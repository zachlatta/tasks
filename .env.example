# Required by `task-tracker serve`. Generate a long random value; never commit .env.
TASK_TRACKER_SECRET=replace-with-a-long-random-secret

TASK_TRACKER_ADDR=127.0.0.1:8080
TASK_TRACKER_PUBLIC_URL=http://127.0.0.1:8080
TASK_TRACKER_DATA_DIR=./data

# Local image storage (development default).
TASK_TRACKER_OBJECT_STORE=local
TASK_TRACKER_LOCAL_OBJECT_DIR=./data/images

# S3-compatible image storage (production alternative).
# TASK_TRACKER_OBJECT_STORE=s3
# TASK_TRACKER_S3_ENDPOINT=s3.example.com
# TASK_TRACKER_S3_ACCESS_KEY=replace-me
# TASK_TRACKER_S3_SECRET_KEY=replace-me
# TASK_TRACKER_S3_BUCKET=task-tracker-images
# TASK_TRACKER_S3_REGION=us-east-1
# TASK_TRACKER_S3_USE_SSL=true
